# =============================================================================
# /etc/mysql/mariadb.conf.d/99-binlog.cnf
# MariaDB Binary Log Konfiguration für Point-in-Time Recovery
# =============================================================================

[mysqld]

# Binary Log aktivieren
log_bin                = /var/log/mysql/mysql-bin
binlog_format          = ROW

# Logs nach 3 Tagen automatisch löschen (Fallback, restic übernimmt Retention)
expire_logs_days       = 3

# Jede Transaktion sofort auf Disk schreiben (kein Datenverlust bei Crash)
sync_binlog            = 1

# Pro-Transaktion Binlog-Commit (InnoDB/Aria konsistent)
innodb_flush_log_at_trx_commit = 1

# Maximale Größe pro Binary Log Datei
max_binlog_size        = 100M

# Server ID (muss eindeutig sein, relevant bei Replikation)
server_id              = 1
